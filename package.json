{
  "name": "client-to-server",
  "version": "1.0.0",
  "description": "Утилита для первичной очистки клиентского Minecraft-модпака перед сборкой серверной версии",
  "author": "F_aN | Алексей",
  "main": "index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "dev:cli": "tsx src/cli/main.ts",
    "dev:backend": "tsx src/backend/headless-runner.ts",
    "dev:tui": "tsx src/tui/main.tsx",
    "build": "tsc -p tsconfig.build.json",
    "test": "node --require tsx/cjs --test --test-concurrency=1 --test-isolation=none",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('Lint is not configured yet')\""
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@types/react": "^19.2.14",
    "adm-zip": "^0.5.16",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
